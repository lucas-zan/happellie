APP_ENV=dev
APP_PORT=8000
DATABASE_URL=sqlite:///./data/happyellie.db
ASSET_DIR=./data/assets
FRONTEND_API_BASE=http://127.0.0.1:8000/api/v1
VOCAB_LIBRARY_PATH=./config/vocab_library.json
PROFILE_RECENT_SESSIONS_LIMIT=8
PLANNER_CANDIDATE_LIMIT=14
DEFAULT_STUDENT_ID=student-demo

# Generic OpenAI-compatible AI provider configuration.
# Fill these four fields and HappyEllie will use your model for lesson planning,
# lesson generation, and profile analysis.
AI_PROVIDER_NAME=compatible
AI_ENABLE_FALLBACK=true
AI_TIMEOUT_SECONDS=30
AI_TEMPERATURE=0.25
AI_API_KEY=
AI_BASE_URL=
AI_DEFAULT_MODEL=
AI_PLANNER_MODEL=
AI_GENERATOR_MODEL=
AI_PROFILE_MODEL=

# Optional pricing metadata for the admin panel cost analysis.
AI_INPUT_COST_PER_MILLION=0
AI_OUTPUT_COST_PER_MILLION=0
AI_HEADERS_JSON={}

# Backward-compatible aliases for the previous Qwen-only setup.
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-flash
QWEN_TIMEOUT_SECONDS=20

# TTS stays disabled by default for the AI-first prototype.
TTS_PROVIDER=disabled
